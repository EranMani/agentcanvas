# AgentCanvas — Environment Variables
# Copy this file to src/backend/.env and fill in your values.
# Never commit the real .env file — it is listed in .gitignore.

# ─── LLM Provider ─────────────────────────────────────────────────────────────

# Which LLM provider to use: "anthropic" or "openai"
LLM_PROVIDER=anthropic

# Anthropic API key — obtain from https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key — obtain from https://platform.openai.com → API Keys
OPENAI_API_KEY=sk-...

# ─── Storage ──────────────────────────────────────────────────────────────────

# Directory where graph JSON files are stored (relative to src/backend)
GRAPHS_DIR=./data/graphs

# ─── Demo Tier — Access Control ───────────────────────────────────────────────

# Owner's API key used for demo free-tier LLM calls; set in Railway secrets — never commit this
ERAN_API_KEY=

# Number of free LLM calls allowed per browser session before the API key modal appears
FREE_USES_PER_SESSION=3

# ─── Production Only ──────────────────────────────────────────────────────────

# Path to the compiled React build directory, served as static files by FastAPI in production
FRONTEND_DIST_DIR=../frontend/dist

# Per-IP rate limit applied to LLM endpoints (uses SlowAPI format: "N/period")
SLOWAPI_RATE_LIMIT=30/minute
